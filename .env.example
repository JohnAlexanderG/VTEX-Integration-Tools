# Configuración VTEX API
X-VTEX-API-AppKey=tu_app_key_aqui
X-VTEX-API-AppToken=tu_app_token_aqui
VTEX_ACCOUNT_NAME=nombre_cuenta_vtex
VTEX_ENVIRONMENT=vtexcommercestable

# Fotos proveedores
FOTOS_PROVEEDORES_USER=usuario_aqui
FOTOS_PROVEEDORES_PASSWORD=password_aqui

# FTP — Pipeline de inventario (mismo servidor que Terraform-AWS-Lambda-FTP2S3)
FTP_SERVER=ftp.ejemplo.com
FTP_USER=usuario_ftp
FTP_PASSWORD=password_ftp
FTP_PORT=21

# AWS — Invocación de Lambda1
AWS_REGION=us-east-2
LAMBDA1_FUNCTION_NAME=demo-lambda